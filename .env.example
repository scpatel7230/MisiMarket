# .env.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Database ─────────────────────────────────────────────────
# Get from Supabase: Settings > Database > Connection string (URI)
# Or from Neon: Dashboard > Connection Details
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/misimarket?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Google Document AI (Invoice OCR) ─────────────────────────
# 1. Enable Document AI API in Google Cloud Console
# 2. Create a "Form Parser" or "Invoice Parser" processor
# 3. Create a service account, download the JSON key
GOOGLE_CLOUD_PROJECT_ID=""
GOOGLE_CLOUD_PROCESSOR_ID=""
# Path to your downloaded service account key file
GOOGLE_APPLICATION_CREDENTIALS="./google-service-account.json"

# ── Supabase (File Storage for invoices) ─────────────────────
# Get from Supabase: Settings > API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key — SERVER SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=""

# ── Resend (Email Alerts) ─────────────────────────────────────
# Sign up at resend.com → API Keys → Create
RESEND_API_KEY=""
ALERT_FROM_EMAIL="alerts@misimarket.com"
# Overcharge threshold in USD — alert sent when invoice exceeds this
OVERCHARGE_ALERT_THRESHOLD_USD="10"

# ── Stripe (Subscription Billing — Phase 6) ──────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
